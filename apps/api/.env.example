# =============================================================================
# DevMind API — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Local dev: docker-compose spins up PostgreSQL on port 5433
# Production: Railway injects DATABASE_URL automatically
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://devmind:devmind@localhost:5433/devmind"

# -----------------------------------------------------------------------------
# Cache (Redis)
# Local dev: docker-compose spins up Redis on port 6380
# Production: Railway injects REDIS_URL automatically
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6380"

# -----------------------------------------------------------------------------
# Auth
# Generate in production with: openssl rand -hex 64
# The app will crash at startup if this is left as default in production.
# -----------------------------------------------------------------------------
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# -----------------------------------------------------------------------------
# Anthropic (Claude API) — REQUIRED
# Get your key at: https://console.anthropic.com
# Required for all agent functionality.
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# -----------------------------------------------------------------------------
# Brave Search API — OPTIONAL
# Enables the Researcher agent to search the web.
# Get your key at: https://api.search.brave.com/app/dashboard
# If not set, Researcher falls back to summarisation only.
# -----------------------------------------------------------------------------
BRAVE_API_KEY=""

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# URL of the Next.js frontend (used for CORS allow-list)
# Production: set to your Vercel deployment URL, e.g. https://devmind.vercel.app
FRONTEND_URL="http://localhost:3000"
